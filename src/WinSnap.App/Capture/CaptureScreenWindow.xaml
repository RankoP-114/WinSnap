<Window x:Class="WinSnap.App.Capture.CaptureScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinSnap.App.Capture"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Cursor="Cross"
        InputMethod.IsInputMethodEnabled="False">
    <Grid x:Name="RootGrid" Background="#01000000">
        <!-- 该屏物理像素层（ScaleTransform 1/屏DPI，1:1 精确） -->
        <Canvas x:Name="RootCanvas" HorizontalAlignment="Left" VerticalAlignment="Top"
                Background="#01000000">
            <Image x:Name="BackgroundImage" Canvas.Left="0" Canvas.Top="0"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   IsHitTestVisible="False" />
            <Rectangle x:Name="DimOverlay" Canvas.Left="0" Canvas.Top="0"
                       Fill="#9E000000" IsHitTestVisible="False" Visibility="Collapsed" />
            <Image x:Name="SelectionImage" Canvas.Left="0" Canvas.Top="0"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   IsHitTestVisible="False" Visibility="Collapsed" />
            <Rectangle x:Name="HoverBorder" Stroke="#FF0078D4" StrokeThickness="2"
                       IsHitTestVisible="False" Visibility="Collapsed" />
            <Rectangle x:Name="SelectionBorder" Stroke="#FF0078D4" StrokeThickness="2"
                       IsHitTestVisible="False" Visibility="Collapsed" />
            <Canvas x:Name="HandleCanvas" IsHitTestVisible="False" />
            <Border x:Name="SizeHint" Background="#E61F1F1F" CornerRadius="4" Padding="8,3"
                    IsHitTestVisible="False" Visibility="Collapsed">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="22" />
            </Border>
        </Canvas>

        <!-- DIU 层：放大镜 + WinUI3 工具栏 + 文字输入 -->
        <Canvas x:Name="OverlayLayer">
            <local:MagnifierControl x:Name="Magnifier" IsHitTestVisible="False" Visibility="Collapsed" />

            <Border x:Name="Toolbar" Visibility="Collapsed" Background="#F21F1F1F"
                    CornerRadius="8" Padding="6,5" BorderBrush="#26FFFFFF" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5" Color="Black" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="ToolbarDragHandle" Width="28" Margin="0,0,5,0"
                            Background="#33FFFFFF" BorderBrush="#26FFFFFF" BorderThickness="1"
                            CornerRadius="5" Cursor="SizeAll" ToolTip="移动工具栏">
                        <UniformGrid Columns="2" Rows="3" Width="10" Height="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="3" Height="3" Fill="#CCFFFFFF" />
                            <Ellipse Width="3" Height="3" Fill="#CCFFFFFF" />
                            <Ellipse Width="3" Height="3" Fill="#CCFFFFFF" />
                            <Ellipse Width="3" Height="3" Fill="#CCFFFFFF" />
                            <Ellipse Width="3" Height="3" Fill="#CCFFFFFF" />
                            <Ellipse Width="3" Height="3" Fill="#CCFFFFFF" />
                        </UniformGrid>
                    </Border>
                    <ToggleButton x:Name="RectTool" Content="▭" Style="{StaticResource ToolToggleStyle}" ToolTip="矩形" />
                    <ToggleButton x:Name="EllipseTool" Content="◯" Style="{StaticResource ToolToggleStyle}" ToolTip="椭圆" />
                    <ToggleButton x:Name="ArrowTool" Content="↗" Style="{StaticResource ToolToggleStyle}" ToolTip="箭头" />
                    <ToggleButton x:Name="PenTool" Content="✎" Style="{StaticResource ToolToggleStyle}" ToolTip="画笔" />
                    <ToggleButton x:Name="TextTool" Content="A" Style="{StaticResource ToolToggleStyle}" ToolTip="文字" />
                    <ToggleButton x:Name="MosaicTool" Content="▦" Style="{StaticResource ToolToggleStyle}" ToolTip="马赛克" />
                    <ToggleButton x:Name="NumberTool" Content="①" Style="{StaticResource ToolToggleStyle}" ToolTip="序号" />
                    <Border x:Name="AnnotationSeparator" Width="1" Background="#26FFFFFF" Margin="5,4" />
                    <Button x:Name="UndoButton" Content="&#xE7A7;" Style="{StaticResource ToolButtonStyle}" ToolTip="撤销 Ctrl+Z" />
                    <Button x:Name="RedoButton" Content="&#xE7A6;" Style="{StaticResource ToolButtonStyle}" ToolTip="重做 Ctrl+Y" />
                    <Border x:Name="ActionSeparator" Width="1" Background="#26FFFFFF" Margin="5,4" />
                    <Button x:Name="PinButton" Content="&#xE718;" Style="{StaticResource ToolButtonStyle}" ToolTip="钉到屏幕" />
                    <Button x:Name="SaveButton" Content="&#xE74E;" Style="{StaticResource ToolButtonStyle}" ToolTip="保存" />
                    <Button x:Name="CancelButton" Content="&#xE711;" Style="{StaticResource ToolButtonStyle}"
                            ToolTip="取消（右键 / Esc）" />
                    <Button x:Name="ConfirmButton" Content="&#xE73E;" Style="{StaticResource AccentButtonStyle}"
                            Margin="3,0,0,0" ToolTip="完成并复制（双击 / ⏎）" />
                </StackPanel>
            </Border>

            <TextBox x:Name="TextInputBox" Visibility="Collapsed" MinWidth="60"
                     Background="#FFFFFFE0" Foreground="Black" FontSize="16"
                     BorderBrush="#FF0078D4" BorderThickness="1" Padding="2,0"
                     InputMethod.IsInputMethodEnabled="True" />
        </Canvas>
    </Grid>
</Window>
